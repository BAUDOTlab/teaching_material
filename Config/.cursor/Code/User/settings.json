{
  // --- 🧭 UI / WORKBENCH ---
  "window.commandCenter": true,
  "window.restoreWindows": "none",
  "workbench.list.openMode": "doubleClick",
  "workbench.colorTheme": "Visual Studio Light",
  "workbench.startupEditor": "none",
  // --- 📁 FILES / EXPLORER ---
  "files.autoSave": "afterDelay",
  "files.associations": {
    "*.Rmd": "rmd",
    "*.R": "r"
  },
  "files.eol": "\n",
  "files.hotExit": "onExitAndWindowClose",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.watcherExclude": {
    "**.Rproj": true,
    "**/.cache/**": true,
    "**/.Rproj.user/**": true,
    "**/renv/**": true,
    "**/env/**": true
  },
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "search.exclude": {
    "**/renv": true
  },
  // --- 🧠 EDITOR CORE ---
  "editor.formatOnSave": true,
  "editor.inlineSuggest.enabled": true,
  "editor.tabSize": 2,
  "editor.rulers": [80, { "color": "#b22222", "column": 120 }],
  // --- 🗺 DOCUMENT NAVIGATION (Quarto / Markdown / Rmd) ---
  // Sticky scroll: pins the current heading at the top of the editor while scrolling
  "editor.stickyScroll.enabled": true,
  "editor.stickyScroll.maxLineCount": 3,
  // Breadcrumbs: heading hierarchy bar at the top of each file
  "breadcrumbs.enabled": true,
  "breadcrumbs.filePath": "last",
  "breadcrumbs.symbolPath": "on",
  // Outline panel: always show up to H4 depth, keep symbols sorted by position
  "outline.showMarkdownHeaderDepth": true,
  "outline.collapseItems": "alwaysExpand",
  // --- 🐍 PYTHON / UV ---
  "python.defaultInterpreterPath": "/usr/bin/python",
  "python.createEnvironment.trigger": "off",
  "python.terminal.activateEnvironment": false,
  // uv integration (use uvx manually in terminal/tasks)
  "python.envFile": "${workspaceFolder}/.env",
  "[python]": {
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    },
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "ruff.lineLength": 72,
  // --- 📊 R / QUARTO ---
  "r.bracketedPaste": true,
  "r.plot.useHttpgd": true,
  "r.plot.defaults.fullWindowMode": true,
  "r.removeLeadingComments": true,
  "r.session.levelOfObjectDetail": "Normal",
  // radian: enhanced R terminal (syntax highlighting, multiline editing, history)
  "r.rterm.linux": "/home/bastien/.local/bin/radian",
  "r.rterm.option": [
    "--no-save",
    "--no-restore",
    "--quiet"
  ],
  "r.helpPanel.enableHoverLinks": true,
  // Use air for formatting
  "r.formatting.provider": "external",
  "r.formatting.command": "/home/bastien/.local/bin/air",
  "[r]": {
    "editor.formatOnSave": true,
    "editor.wordSeparators": "`~!@#%$^&*()-=+[{]}\\|;:'\",<>/?"
  },
  "[rmd]": {
    "editor.formatOnSave": true
  },
  "quarto.visualEditor.spellingDictionary": "en_GB",
  // Assist Panel: real-time equation + figure thumbnail in the sidebar
  // Open with: Ctrl+Shift+P → "Quarto: Show Assist Panel"
  // Live preview (equations / Mermaid): Ctrl+Shift+L above any math block
  // Full document preview (HTML side pane): Ctrl+Shift+K
  "quarto.render.previewType": "internal",
  // --- 🔧 DOCKER / YAML ---
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true
    },
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "docker.extension.enableComposeLanguageServer": false,
  // --- ✏️ SPELL CHECK (cSpell) ---
  "cSpell.enableFiletypes": ["quarto"],
  "cSpell.language": "en-GB,fr-FR",
  // --- 🔀 GIT / GITLENS ---
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.pruneOnFetch": true,
  "githubIssues.issueBranchTitle": "fix/issue${issueNumber}",
  "githubIssues.workingIssueFormatScm": "fix: ${issueTitle}\n\nFixes ${issueNumberLabel}",
  "githubPullRequests.fileListLayout": "tree",
  "githubPullRequests.pullBranch": "never",
  "gitlens.launchpad.indicator.enabled": false,
  "gitlens.ai.model": "gitkraken",
  "gitlens.ai.gitkraken.model": "gemini:gemini-2.0-flash",
  // --- 🔍 MARKDOWNLINT ---
  "markdownlint.lintWorkspaceGlobs": [
    "**/*.{md,mkd,mdwn,mdown,markdown,markdn,mdtxt,mdtext,qmd,rmd}",
    "!**/node_modules",
    "!**/vendor",
    "!**/.git"
  ],
  // --- 📝 BETTER COMMENTS ---
  "better-comments.tags": [
    {
      "tag": "!",
      "color": "#FF2D00"
    },
    {
      "tag": "?",
      "color": "#3498DB"
    },
    {
      "tag": "//",
      "color": "#474747",
      "strikethrough": true
    },
    {
      "tag": "todo",
      "color": "#FF8C00"
    },
    {
      "tag": "*",
      "color": "#98C379"
    }
  ],
  // --- 🔒 TELEMETRY ---
  "redhat.telemetry.enabled": false
}
